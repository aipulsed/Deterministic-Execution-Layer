{
  "level": "info",
  "format": "json",
  "transports": [
    {
      "type": "console",
      "level": "debug",
      "colorize": true
    },
    {
      "type": "file",
      "level": "info",
      "filename": "logs/app.log",
      "maxsize": 5242880,
      "maxFiles": 5
    },
    {
      "type": "file",
      "level": "error",
      "filename": "logs/error.log",
      "maxsize": 5242880,
      "maxFiles": 5
    }
  ],
  "exceptionHandlers": [
    {
      "type": "file",
      "filename": "logs/exceptions.log"
    }
  ]
}
